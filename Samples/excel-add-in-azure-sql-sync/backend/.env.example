# .env — Azure SQL connection config for the backend server
# Copy this file to .env and fill in your values.
# DO NOT commit your .env file to source control.

SQL_SERVER=your-server.database.windows.net
SQL_DATABASE=your_database
SQL_USER=your_sql_user
SQL_PASSWORD=your_sql_password
SQL_PORT=1433

# Optional: set a shared secret. The add-in must send x-api-key: <value>
API_KEY=

# Port the backend HTTP server listens on
PORT=3001
